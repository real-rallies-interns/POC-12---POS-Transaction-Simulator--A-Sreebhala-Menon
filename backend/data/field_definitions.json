{
  "disclaimer": "SYNTHETIC — NOT REAL TRANSACTION DATA",
  "source": "Real Rails PoC #12 — POS Transaction Simulator",
  "field_definitions": [
    {"field":"transaction_id",    "type":"string",  "format":"TXN-{10 hex}",          "description":"Unique transaction identifier",                         "source":"Simulator"},
    {"field":"timestamp",         "type":"string",  "format":"ISO 8601 UTC",           "description":"Transaction datetime in UTC",                           "source":"Simulator"},
    {"field":"merchant",          "type":"string",  "format":"free text",              "description":"Merchant trading name",                                 "source":"merchants.json"},
    {"field":"merchant_city",     "type":"string",  "format":"free text",              "description":"City where merchant is located",                        "source":"merchants.json"},
    {"field":"merchant_country",  "type":"string",  "format":"ISO 3166-1 alpha-3",     "description":"Country code of merchant",                              "source":"merchants.json"},
    {"field":"merchant_mcc",      "type":"string",  "format":"4-digit ISO 18245",      "description":"Merchant Category Code",                                "source":"ISO 18245"},
    {"field":"merchant_category", "type":"string",  "format":"free text",              "description":"Human-readable MCC category label",                     "source":"merchants.json"},
    {"field":"merchant_lat",      "type":"float",   "format":"decimal degrees",        "description":"Merchant latitude for map rendering",                   "source":"merchants.json"},
    {"field":"merchant_lng",      "type":"float",   "format":"decimal degrees",        "description":"Merchant longitude for map rendering",                  "source":"merchants.json"},
    {"field":"amount",            "type":"float",   "format":"2 decimal places",       "description":"Transaction amount in the stated currency",              "source":"Simulator"},
    {"field":"currency",          "type":"string",  "format":"ISO 4217",               "description":"Transaction currency code",                             "source":"ISO 4217"},
    {"field":"card_brand",        "type":"string",  "format":"enum",                   "description":"Card network brand (Visa, Mastercard, Amex, Discover)",  "source":"UK Finance 2022"},
    {"field":"card_type",         "type":"string",  "format":"enum",                   "description":"Credit, Debit, or Prepaid",                             "source":"UK Finance 2022"},
    {"field":"last4",             "type":"string",  "format":"4 digits",               "description":"Last 4 digits of card PAN (synthetic)",                 "source":"Simulator"},
    {"field":"issuing_bank",      "type":"string",  "format":"free text",              "description":"Name of card-issuing bank",                             "source":"card_brands.json"},
    {"field":"entry_method",      "type":"string",  "format":"enum",                   "description":"How card was presented at terminal",                    "source":"Fed Reserve 2022"},
    {"field":"status",            "type":"string",  "format":"APPROVED | DECLINED",    "description":"Final transaction outcome",                             "source":"Simulator"},
    {"field":"authorization_code","type":"string",  "format":"6 hex chars",            "description":"Issuer approval code (null if declined)",               "source":"Simulator"},
    {"field":"decline_code",      "type":"string",  "format":"ISO 8583",               "description":"ISO 8583 response code for declined transactions",       "source":"ISO 8583"},
    {"field":"decline_reason",    "type":"string",  "format":"free text",              "description":"Human-readable decline label",                          "source":"CFPB / ISO 8583"},
    {"field":"decline_category",  "type":"string",  "format":"enum",                   "description":"Grouped decline category",                              "source":"CFPB"},
    {"field":"fraud_score",       "type":"integer", "format":"0–100",                  "description":"Synthetic risk score (0 = low, 100 = high)",             "source":"Simulator"},
    {"field":"offline_auth",      "type":"boolean", "format":"true | false",           "description":"Whether transaction was authorised offline (SAF)",       "source":"Simulator"},
    {"field":"processing_ms",     "type":"integer", "format":"milliseconds",           "description":"Simulated end-to-end processing latency",               "source":"Simulator"},
    {"field":"emv_handshake",     "type":"array",   "format":"list of EMV steps",      "description":"Full EMV chip handshake sequence (Chip/Contactless only)","source":"EMVCo Book 3 v4.3"},
    {"field":"store_and_forward", "type":"boolean", "format":"true | false",           "description":"Transaction queued for later sync (offline mode)",      "source":"Simulator"},
    {"field":"risk_flag",         "type":"boolean", "format":"true | false",           "description":"High-risk flag: offline + amount > £200",               "source":"Simulator"},
    {"field":"cfpb_compliant",    "type":"boolean", "format":"true | false",           "description":"Confirms receipt fields meet CFPB Reg E requirements",  "source":"CFPB Reg E"},
    {"field":"data_label",        "type":"string",  "format":"free text",              "description":"Mandatory synthetic data disclaimer",                   "source":"Real Rails"}
  ]
}
